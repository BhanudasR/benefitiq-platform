# BenefitIQ environment (EXAMPLE — safe to commit; contains no real secrets).
# Local: copy to `.env` (gitignored). Production: set these in the HOST SECRET STORE
# (Render dashboard), never in the repo.

# ---- App ----
BIQ_ENV=local                       # production in prod
BIQ_AUTO_CREATE_TABLES=true         # MUST be false in production (schema comes from `alembic upgrade head`)

# ---- Database (canonical + governance + audit) ----
# Local dev: local Postgres or SQLite (sqlite:///./benefitiq_local.db).
# Production: managed Postgres connection string from the host secret store.
BIQ_DATABASE_URL=postgresql+psycopg2://biq:biq@localhost:5432/benefitiq

# ---- Object storage for immutable raw uploads ----
BIQ_STORAGE_BACKEND=local           # production: s3
BIQ_STORAGE_LOCAL_ROOT=./_raw_store
BIQ_S3_ENDPOINT=http://localhost:9000
BIQ_S3_BUCKET=biq-raw
BIQ_S3_ACCESS_KEY=minioadmin        # production: scoped key from host secret store — never commit real keys
BIQ_S3_SECRET_KEY=minioadmin        # production: from host secret store
BIQ_S3_REGION=ap-south-1

# ---- Auth ----
BIQ_JWT_SECRET=change-me-in-prod    # production: strong random secret from host secret store

# ---- CORS (SPA origin allowlist; comma-separated) ----
BIQ_CORS_ORIGINS=http://localhost:5173   # production: the EXACT deployed frontend URL(s), no wildcards
